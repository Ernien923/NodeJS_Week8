{
  "name": "school-grade-system",
  "version": "1.0.0",
  "private": true,
  "description": "W8 考場 — 校園成績系統：你設計 schema，讓它活過來。",
  "scripts": {
    "start": "node scripts/check-docker.js && docker compose up -d && node scripts/wait-db.js",
    "stop": "docker compose stop",
    "db:reset": "docker compose down -v && docker compose up -d && node scripts/wait-db.js",
    "dev": "node server/www.js",
    "migration:generate": "typeorm migration:generate -d ./db/data-source.js -o",
    "migration:run": "typeorm migration:run -d ./db/data-source.js",
    "migration:revert": "typeorm migration:revert -d ./db/data-source.js",
    "seed": "node db/seed.js",
    "test": "jest --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
